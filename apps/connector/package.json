{
  "name": "@codex-relay/connector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "codex-relay-connector": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "install:autostart": "powershell -ExecutionPolicy Bypass -File ./scripts/install-autostart.ps1",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codex-relay/contracts": "workspace:*",
    "dotenv": "^17.4.2",
    "ws": "^8.18.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6"
  }
}
